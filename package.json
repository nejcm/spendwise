{
  "name": "spendwise",
  "version": "0.0.55",
  "private": true,
  "packageManager": "pnpm@10.33.3",
  "engines": {
    "node": "^22.13.0 || >=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/user/repo-name.git"
  },
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "start": "expo start",
    "prebuild": "pnpm expo prebuild",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "xcode": "xed -b ios",
    "doctor": "npx expo-doctor@latest",
    "assets:jpg": "tsx scripts/svg-to-jpg.ts",
    "preinstall": "npx only-allow pnpm",
    "start:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run start",
    "prebuild:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "prebuild:development": "cross-env EXPO_PUBLIC_APP_ENV=development STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "android:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run android",
    "ios:preview": "cross-env EXPO_PUBLIC_APP_ENV=preview pnpm run ios",
    "start:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run start",
    "prebuild:production": "cross-env EXPO_PUBLIC_APP_ENV=production STRICT_ENV_VALIDATION=1 pnpm run prebuild",
    "android:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run android",
    "ios:production": "cross-env EXPO_PUBLIC_APP_ENV=production pnpm run ios",
    "build:development:ios": "eas build --profile development --platform ios",
    "build:development:android": "eas build --profile development --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:production:ios": "eas build --profile production --platform ios",
    "build:production:android": "eas build --profile production --platform android",
    "prepare": "husky",
    "app-release": "cross-env SKIP_BRANCH_PROTECTION=true np --no-publish --no-cleanup --no-release-draft --message \"chore(release): v%s [skip ci]\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "tsc --noEmit",
    "lint:all": "pnpm run lint && pnpm run lint:ts && pnpm run lint:translations",
    "format": "eslint . --fix",
    "lint:translations": "eslint ./src/translations/ --fix --ext .json",
    "test": "jest",
    "verify": "pnpm run lint && pnpm run lint:ts && pnpm run lint:translations && pnpm run test",
    "test:ci": "pnpm run test --coverage",
    "test:watch": "pnpm run test --watch",
    "install-maestro": "curl -Ls 'https://get.maestro.mobile.dev' | bash",
    "e2e-test": "maestro test .maestro/ -e APP_ID=com.obytes.development",
    "knip:check": "pnpm exec knip"
  },
  "dependencies": {
    "@date-fns/utc": "~2.1.1",
    "@expo-google-fonts/inter": "~0.4.2",
    "@expo/metro-runtime": "~55.0.11",
    "@gorhom/bottom-sheet": "~5.2.13",
    "@react-native-community/datetimepicker": "8.6.0",
    "@react-native-picker/picker": "~2.11.4",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/react-form": "~1.29.1",
    "@tanstack/react-pacer": "~0.22.0",
    "@tanstack/react-query": "~5.100.9",
    "app-icon-badge": "~0.1.2",
    "date-fns": "~4.1.0",
    "es-toolkit": "~1.46.1",
    "expo": "~55.0.23",
    "expo-constants": "~55.0.16",
    "expo-crypto": "~55.0.14",
    "expo-dev-client": "~55.0.32",
    "expo-document-picker": "~55.0.13",
    "expo-file-system": "~55.0.19",
    "expo-font": "~55.0.7",
    "expo-haptics": "~55.0.14",
    "expo-image": "~55.0.10",
    "expo-image-manipulator": "~55.0.16",
    "expo-image-picker": "~55.0.20",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.15",
    "expo-local-authentication": "~55.0.13",
    "expo-localization": "~55.0.13",
    "expo-notifications": "~55.0.22",
    "expo-router": "~55.0.14",
    "expo-sharing": "~55.0.18",
    "expo-splash-screen": "~55.0.20",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.6",
    "expo-system-ui": "~55.0.17",
    "expo-updates": "~55.0.21",
    "fuse.js": "~7.3.0",
    "i18next": "~26.0.9",
    "lucide-react-native": "~1.14.0",
    "moti": "~0.30.0",
    "posthog-react-native": "~4.44.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-error-boundary": "~6.1.1",
    "react-i18next": "~17.0.6",
    "react-native": "0.83.6",
    "react-native-edge-to-edge": "~1.8.1",
    "react-native-enriched-markdown": "~0.5.0",
    "react-native-flash-message": "~0.4.2",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-gifted-charts": "~1.4.76",
    "react-native-keyboard-controller": "1.20.7",
    "react-native-mmkv": "~4.3.1",
    "react-native-nitro-modules": "~0.35.6",
    "react-native-reanimated": "~4.3.0",
    "react-native-restart": "0.0.27",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-sortables": "~1.9.4",
    "react-native-svg": "15.15.3",
    "react-native-url-polyfill": "~3.0.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "~0.8.3",
    "react-query-kit": "~3.3.3",
    "simple-icons": "~16.18.1",
    "tailwind-merge": "~3.5.0",
    "tailwind-variants": "~3.2.2",
    "uniwind": "~1.6.3",
    "zod": "~4.4.3",
    "zustand": "~5.0.13"
  },
  "devDependencies": {
    "@antfu/eslint-config": "~7.7.3",
    "@babel/core": "~7.29.0",
    "@commitlint/cli": "~20.5.3",
    "@commitlint/config-conventional": "~20.5.3",
    "@dev-plugins/react-query": "~0.4.0",
    "@eslint-react/eslint-plugin": "~2.13.0",
    "@expo/config": "~55.0.16",
    "@react-native-community/cli": "~20.1.3",
    "@tailwindcss/cli": "~4.2.4",
    "@testing-library/react-native": "~13.3.3",
    "@types/better-sqlite3": "~7.6.13",
    "@types/invariant": "~2.2.37",
    "@types/jest": "~29.5.14",
    "@types/react": "~19.2.14",
    "babel-plugin-module-resolver": "~5.0.3",
    "better-sqlite3": "~12.9.0",
    "cross-env": "~10.1.0",
    "dotenv": "~17.4.2",
    "eslint": "~9.39.4",
    "eslint-import-resolver-typescript": "~4.4.4",
    "eslint-plugin-better-tailwindcss": "~4.5.0",
    "eslint-plugin-i18n-json": "~4.0.1",
    "eslint-plugin-import": "~2.32.0",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "~0.5.2",
    "eslint-plugin-testing-library": "~7.16.2",
    "eslint-plugin-unicorn": "~64.0.0",
    "husky": "~9.1.7",
    "jest": "~29.7.0",
    "jest-expo": "~55.0.17",
    "jest-junit": "~17.0.0",
    "knip": "~6.11.0",
    "lint-staged": "~17.0.2",
    "np": "~11.2.0",
    "sharp": "~0.34.5",
    "tailwindcss": "4.2.4",
    "tsx": "~4.21.0",
    "typescript": "~5.9.3"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-restart"
        ]
      }
    },
    "install": {
      "exclude": [
        "eslint-config-expo",
        "react-native-worklets"
      ]
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "osMetadata": {
    "initVersion": "9.0.0"
  }
}
